<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteForge.UI.MainPage"
             xmlns:viewModels="clr-namespace:NoteForge.UI.ViewModels"
             xmlns:models="clr-namespace:NoteForge.UI.Models"
             x:DataType="viewModels:NotesViewModel">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            <CollectionView
                ItemsSource="{Binding Notes}" HeightRequest="200"
                SelectedItem="{Binding SelectedNote}"
                SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Note">
                        <Label Text="{Binding Title}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Entry Placeholder="Note title" Text="{Binding Title}" />
            <Editor Placeholder="Write your note..."
                    AutoSize="TextChanges"
                    HeightRequest="300"
                    Text="{Binding Content}" />
            <Button
                Text="New Note" Command="{Binding CreateNoteCommand}" />

            <Button Text="Save Note" Command="{Binding SaveNoteCommand}" />

            <Button Text="Clear Editor" Command="{Binding ClearEditorCommand}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" />


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>